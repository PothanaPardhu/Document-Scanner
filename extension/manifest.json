{
  "manifest_version": 3,
  "name": "Focus-Flow AI",
  "version": "1.0",
  "description": "Transforms overwhelming content into structured, actionable study workflows.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tts"
  ],
  "host_permissions": [
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ]
}
